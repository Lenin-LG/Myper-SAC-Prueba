@model Trabajadores.Web.Models.WorkerViewModel
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

<form asp-action="Create" method="post" enctype="multipart/form-data">

    <input asp-for="FirstName" class="form-control mb-2" placeholder="Nombres" />
    <input asp-for="LastName" class="form-control mb-2" placeholder="Apellidos" />

    <select asp-for="DocumentType" class="form-control mb-2">
        <option value="1">DNI</option>
        <option value="2">Pasaporte</option>
    </select>

    <input asp-for="DocumentNumber" class="form-control mb-2" placeholder="Documento" />

    <select asp-for="Gender" class="form-control mb-2">
        <option value="1">Masculino</option>
        <option value="2">Femenino</option>
    </select>

    <input asp-for="BirthDate" type="date" class="form-control mb-2" />
    <input asp-for="Address" class="form-control mb-2" placeholder="Dirección" />
    <input type="file" name="Photo" class="form-control mb-2" />

    <button class="btn btn-success">Guardar</button>

</form>
